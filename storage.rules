rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Catalogue ──────────────────────────────────────────────────────────
    // Lecture publique (storefront), écriture réservée aux utilisateurs authentifiés.
    // La vérification admin se fait côté app (seul l'admin a accès à l'UI d'upload).
    match /catalog/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Défaut : tout refuser ───────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
