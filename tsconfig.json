{
  "compileOnSave": false,
  "compilerOptions": {
    "resolveJsonModule": true,
    "baseUrl": "./",
    "downlevelIteration": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "es2020",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "paths": {
      "@app/*": [
        "./src/app/*"
      ],
      "@env/*": [
        "./src/environments/*"
      ],
      "@shared/*": [
        "./src/app/shared/*"
      ],
      "@modals/*": [
        "./src/app/shared/modals/*"
      ],
      "@helpers/*": [
        "./src/app/shared/helpers/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ]
    },
    "useDefineForClassFields": false
  }
}
